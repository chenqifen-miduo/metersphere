{
  "mcpServers": {
    "metersphere": {
      "command": "node",
      "args": ["metersphere-mcp/dist/index.js"],
      "env": {
        "MS_BASE_URL": "https://msp.ebcone.cn",
        "MS_AGENT_TOKEN": "msat_replace_with_your_token",
        "MS_PROJECT_ID": "your-project-id",
        "MS_TEST_PLAN_ID": "optional-plan-id"
      }
    }
  }
}
