<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.metersphere.functional.mapper.FunctionalCaseXmindFileMapper">
    <resultMap id="BaseResultMap" type="io.metersphere.functional.domain.FunctionalCaseXmindFile">
        <id column="id" jdbcType="VARCHAR" property="id"/>
        <result column="project_id" jdbcType="VARCHAR" property="projectId"/>
        <result column="name" jdbcType="VARCHAR" property="name"/>
        <result column="original_name" jdbcType="VARCHAR" property="originalName"/>
        <result column="file_id" jdbcType="VARCHAR" property="fileId"/>
        <result column="size" jdbcType="BIGINT" property="size"/>
        <result column="storage" jdbcType="VARCHAR" property="storage"/>
        <result column="create_time" jdbcType="BIGINT" property="createTime"/>
        <result column="update_time" jdbcType="BIGINT" property="updateTime"/>
        <result column="create_user" jdbcType="VARCHAR" property="createUser"/>
        <result column="update_user" jdbcType="VARCHAR" property="updateUser"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, project_id, name, original_name, file_id, size, storage,
        create_time, update_time, create_user, update_user
    </sql>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from functional_case_xmind_file
        where id = #{id}
        limit 1
    </select>

    <insert id="insert" parameterType="io.metersphere.functional.domain.FunctionalCaseXmindFile">
        insert into functional_case_xmind_file (id, project_id, name, original_name, file_id, size, storage,
                                               create_time, update_time, create_user, update_user)
        values (#{id}, #{projectId}, #{name}, #{originalName}, #{fileId}, #{size}, #{storage},
                #{createTime}, #{updateTime}, #{createUser}, #{updateUser})
    </insert>

    <update id="updateByPrimaryKeySelective" parameterType="io.metersphere.functional.domain.FunctionalCaseXmindFile">
        update functional_case_xmind_file
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="updateUser != null">update_user = #{updateUser},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteByPrimaryKey">
        delete from functional_case_xmind_file where id = #{id}
    </delete>
</mapper>
