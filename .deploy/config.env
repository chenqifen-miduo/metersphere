# 可变构建配置集中在此，workflow 不硬编码项目制品地址。

BUILD_TYPE=java
JAVA_VERSION=21

CNB_REGISTRY=docker.cnb.cool
CNB_NAMESPACE=miduoyanfa/middleground/metersphere

# 前端静态制品仓库。该仓库需通过 CNB 静态仓库 API 创建：
# POST http://127.0.0.1:8000/api/cnb/static-repositories
# {"dbname":"metersphere","description":"MeterSphere static artifacts","visibility":"private"}
STATIC_REPO_URL=https://cnb.cool/miduoyanfa/MD_static/metersphere

# ZIP 在静态仓库内的路径前缀，最终路径为：
# ${STATIC_REPO_PATH}/${VERSION}/${artifact}.zip
STATIC_REPO_PATH=artifacts
